<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.car4s.mapper.PartMapper">

    <resultMap id="BaseResultMap" type="com.car4s.model.Part">
        <id column="id" property="id" />
        <result column="part_no" property="partNo" />
        <result column="part_name" property="partName" />
        <result column="specification" property="specification" />
        <result column="price" property="price" />
        <result column="stock" property="stock" />
        <result column="supplier" property="supplier" />
    </resultMap>

    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM part WHERE id = #{id}
    </select>

    <select id="findByPartNo" resultMap="BaseResultMap">
        SELECT * FROM part WHERE part_no = #{partNo}
    </select>

    <!-- 确保有这个查询 -->
    <select id="findAll" resultMap="BaseResultMap">
        SELECT * FROM part ORDER BY part_no
    </select>

    <select id="findLowStock" resultMap="BaseResultMap">
        SELECT * FROM part WHERE stock &lt; 10 ORDER BY stock
    </select>

    <insert id="insert" parameterType="com.car4s.model.Part" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO part(part_no, part_name, specification, price, stock, supplier)
        VALUES(#{partNo}, #{partName}, #{specification}, #{price}, #{stock}, #{supplier})
    </insert>

    <update id="update" parameterType="com.car4s.model.Part">
        UPDATE part
        SET part_name = #{partName},
            specification = #{specification},
            price = #{price},
            stock = #{stock},
            supplier = #{supplier}
        WHERE id = #{id}
    </update>

    <update id="updateStock">
        UPDATE part SET stock = #{stock} WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM part WHERE id = #{id}
    </delete>
</mapper>